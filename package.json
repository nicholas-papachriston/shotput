{
	"name": "@agent_oxide/shotput",
	"version": "1.4.0",
	"description": "Zero dependency plug-and-play templating for Bun",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "bun build.ts && bunx dts-bundle-generator --config dts-bundle-generator.config.json",
		"clean:temp": "rm -rf ./test-temp-*",
		"test": "bun test && bun run clean:temp",
		"test:unit": "bun test test/unit && bun run clean:temp",
		"test:integration": "bun test test/integration && bun run clean:temp",
		"test:watch": "bun test --watch && bun run clean:temp",
		"test:coverage": "bun test --coverage && bun run clean:temp",
		"test:conformance": "SHOTPUT_CONFORMANCE_STRICT=1 bun test test/conformance/run-conformance.test.ts",
		"examples": "bun run examples/index.ts",
		"benchmark": "bun run examples/benchmark/run-all.ts",
		"conformance:generate": "uv run test/conformance/jinja2_render.py",
		"fix": "bunx biome check --fix --unsafe .",
		"lint": "bunx biome check .",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build && bun run test"
	},
	"keywords": [
		"bun",
		"node",
		"context engineering",
		"templating",
		"llm",
		"prompt engineering",
		"jinja2"
	],
	"author": "https://github.com/nicholas-papachriston",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nicholas-papachriston/shotput.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest",
		"@types/ejs": "latest",
		"@types/mustache": "latest",
		"@types/node": "latest",
		"@types/nunjucks": "latest",
		"binja": "latest",
		"dts-bundle-generator": "latest",
		"ejs": "latest",
		"effect": "latest",
		"fast-check": "latest",
		"handlebars": "latest",
		"mustache": "latest",
		"nunjucks": "latest",
		"typescript": "latest"
	}
}
